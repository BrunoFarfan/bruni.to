---
interface Props {
	eyebrow?: string;
	title: string;
	description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-header">
	<div class="container">
		{eyebrow && <p class="eyebrow">{eyebrow}</p>}
		<h1>{title}</h1>
		<p class="lead">{description}</p>
	</div>
</header>
