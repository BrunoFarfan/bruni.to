---
interface Props {
	eyebrow?: string;
	title: string;
	description: string;
	externalUrl?: string;
	externalLabel?: string;
}

const { eyebrow, title, description, externalUrl, externalLabel } = Astro.props;
---

<header class="page-header">
	<div class="container">
		{eyebrow && <p class="eyebrow">{eyebrow}</p>}
		{
			externalUrl ? (
				<h1>
					<a
						class="page-title-link"
						href={externalUrl}
						target="_blank"
						rel="noreferrer"
						aria-label={externalLabel ?? `Open ${title} in a new tab`}
					>
						<span>{title}</span>
						<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
							<path d="M7 17 17 7" />
							<path d="M9 7h8v8" />
						</svg>
					</a>
				</h1>
			) : (
				<h1>{title}</h1>
			)
		}
		<p class="lead">{description}</p>
	</div>
</header>
