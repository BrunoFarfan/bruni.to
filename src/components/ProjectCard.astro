---
interface Props {
	title: string;
	href: string;
	eyebrow?: string;
	description: string;
	tags?: string[];
}

const { title, href, eyebrow, description, tags = [] } = Astro.props;
---

<article class="project-card">
	<a class="project-card__link" href={href}>
		<div class="project-card__body">
			{eyebrow && <p class="eyebrow">{eyebrow}</p>}
			<h3>{title}</h3>
			<p class="project-card__description">{description}</p>
		</div>
		{
			tags.length > 0 && (
				<ul class="tag-list" aria-label={`${title} topics`}>
					{tags.map((tag) => (
						<li class="tag-list__item">{tag}</li>
					))}
				</ul>
			)
		}
	</a>
</article>
