---
const year = new Date().getFullYear();

const links = [
    {
        href: "mailto:info@bruni.to",
        label: "Email",
        ariaLabel: "Email Bruno Farfán Miquel",
    },
    {
        href: "https://github.com/BrunoFarfan",
        label: "GitHub",
        ariaLabel: "Open GitHub in a new tab",
    },
    {
        href: "https://www.linkedin.com/in/bruno-farfan-miquel",
        label: "LinkedIn",
        ariaLabel: "Open LinkedIn in a new tab",
    },
    {
        href: "/bruno-farfan-cv.pdf",
        label: "CV",
        ariaLabel: "Open Bruno Farfán's CV in a new tab",
    },
];
---

<footer class="site-footer">
    <div class="container site-footer__inner">
        <p>&copy; {year} Bruno Farfán Miquel</p>
        <div class="site-footer__links" aria-label="Footer links">
            {
                links.map((link) => (
                    <a
                        class="external-text-link"
                        href={link.href}
                        target={
                            link.href.startsWith("mailto:")
                                ? undefined
                                : "_blank"
                        }
                        rel={
                            link.href.startsWith("mailto:")
                                ? undefined
                                : "noopener noreferrer"
                        }
                        aria-label={link.ariaLabel}
                    >
                        <span>{link.label}</span>
                        <svg
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                            focusable="false"
                        >
                            <path d="M7 17 17 7" />
                            <path d="M9 7h8v8" />
                        </svg>
                    </a>
                ))
            }
        </div>
    </div>
</footer>
