---
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	description?: string;
	compact?: boolean;
}

const { id, eyebrow, title, description, compact = false } = Astro.props;
---

<section id={id} class:list={['page-section', compact && 'page-section--compact']}>
	<div class="container">
		{
			(title || description || eyebrow) && (
				<div class="section-heading">
					{eyebrow && <p class="eyebrow">{eyebrow}</p>}
					{title && <h2>{title}</h2>}
					{description && <p class="lead">{description}</p>}
				</div>
			)
		}
		<slot />
	</div>
</section>
