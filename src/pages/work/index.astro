        eyebrow="Selected work"
        title="From DS experimentation to production SWE ownership"
        description="I build production-ready solutions across automation and unstructured data workflows, with end-to-end ownership in startup environments."
    />

    <ScrollShowcase client:load items={workProjects} />
</Layout>
