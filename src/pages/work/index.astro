---
import PageHeader from '../../components/PageHeader.astro';
import ScrollShowcase from '../../components/ScrollShowcase';
import Layout from '../../layouts/Layout.astro';
import { workProjects } from '../../data/projects';
---

<Layout
	title="Selected Work"
	description="Selected professional work across AI reimbursement automation and document intelligence pipelines."
>
	<PageHeader
		eyebrow="Selected work"
		title="Professional AI and software systems."
		description="Polished placeholder case studies for production-oriented work in AI automation, document intelligence, and operational tooling."
	/>

	<ScrollShowcase
		client:load
		items={workProjects}
		kicker="Selected work"
		title="Case-study placeholders for applied AI systems."
		description="Scroll through the current work entries. Each item links to a detail page that can grow into a full case study."
	/>
</Layout>
