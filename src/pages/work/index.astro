---
import PageHeader from '../../components/PageHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Section from '../../components/Section.astro';
import Layout from '../../layouts/Layout.astro';
import { workProjects } from '../../data/projects';
---

<Layout
	title="Selected Work"
	description="Selected professional work across AI reimbursement automation and document intelligence pipelines."
>
	<PageHeader
		eyebrow="Selected work"
		title="Professional AI and software systems."
		description="Polished placeholder case studies for production-oriented work in AI automation, document intelligence, and operational tooling."
	/>

	<Section compact>
		<div class="grid grid--two">
			{
				workProjects.map((project) => (
					<ProjectCard
						title={project.title}
						href={project.href}
						eyebrow={project.eyebrow}
						description={project.summary}
						tags={project.tags}
					/>
				))
			}
		</div>
	</Section>
</Layout>
