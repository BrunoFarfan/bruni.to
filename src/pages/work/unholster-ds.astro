---
import PageHeader from '../../components/PageHeader.astro';
import Section from '../../components/Section.astro';
import Layout from '../../layouts/Layout.astro';
import { workProjects } from '../../data/projects';

const projectTitle = "Unholster";

const project = workProjects.find((project) => project.title === projectTitle);
if (!project) {
	throw new Error(`Project ${projectTitle} not found`);
}
---

<Layout
	title={project.title}
	description="A placeholder selected-work page for document intelligence, NLP extraction, embeddings, and large-scale scraping."
>
	<PageHeader
		eyebrow="Selected work"
		title={project.title}
		description="A professional placeholder case study for building pipelines that extract structure from large, messy document collections."
		externalUrl="https://unholster.com"
		externalLabel="Open Unholster in a new tab"
	/>

	<Section compact>
		<div class="detail-layout">
			<article class="prose">
				<h2>Overview</h2>
				<p>
					This page is a scaffold for a future case study about document intelligence pipelines. It is
					intended to hold a polished narrative around extraction quality, scale, data preparation, and
					downstream usability.
				</p>
				<p>
					The content direction is informed by work with entity extraction, embeddings, KNN retrieval,
					custom scrapers, model fine-tuning, and summarization workflows for large environmental
					document sets.
				</p>

				<h2>Direction</h2>
				<p>
					The future version should explain the pipeline architecture, evaluation approach, data quality
					controls, and how raw documents become structured outputs useful to analysts or product
					surfaces.
				</p>
			</article>

			<aside class="panel detail-aside" aria-label="Project facts">
				<dl class="fact-list">
					<div>
						<dt>Status</dt>
						<dd>{project.status}</dd>
					</div>
					<div>
						<dt>Focus</dt>
						<dd>{project.focus}</dd>
					</div>
					<div>
						<dt>Topics</dt>
						<dd>{project.tags.join(', ')}</dd>
					</div>
				</dl>
			</aside>
		</div>
	</Section>
</Layout>
