---
import Layout from "../layouts/Layout.astro";
import ScrollShowcase from "../components/ScrollShowcase";
import { homeShowcaseItems } from "../data/projects";
---

<Layout
    title="Bruno Farfan Miquel"
    description="A personal portfolio for selected work, technical experiments, and notes across AI, automation, document intelligence, and software engineering."
>
    <section class="hero">
        <div class="container">
            <h1>From notebook experiments to systems people rely on</h1>
            <p class="lead">
                I'm Bruno, a builder who moves between data science experimentation and production software engineering. This portfolio collects professional work and personal experiments that reflect that range: from notebooks to systems in production.
            </p>
        </div>
    </section>

    <ScrollShowcase client:load items={homeShowcaseItems} />
</Layout>
