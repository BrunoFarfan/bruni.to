---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Section from '../components/Section.astro';
import { labProjects, workProjects } from '../data/projects';
---

<Layout
	title="Bruno Farfan Miquel"
	description="A personal portfolio for selected work, technical experiments, and notes across AI, automation, document intelligence, and software engineering."
>
	<section class="hero">
		<div class="container">
			<p class="eyebrow">Software engineer and AI systems builder</p>
			<h1>Building AI-assisted software systems and experimental tools.</h1>
			<p class="lead">
				A personal portfolio for selected work, technical experiments, and notes across AI,
				automation, document intelligence, and software engineering.
			</p>
			<div class="hero__actions" aria-label="Primary actions">
				<a class="button button--primary" href="/work">View selected work</a>
				<a class="button" href="/lab">Visit the lab</a>
				<a class="button" href="/about">About</a>
				<a class="button" href="#contact">Contact</a>
			</div>
		</div>
	</section>

	<Section
		eyebrow="What I build"
		title="Systems that turn messy inputs into useful workflows."
		description="This scaffold frames Bruno's portfolio around practical AI automation, document-heavy software, and experiments that connect models with real products."
	>
		<div class="grid grid--three">
			<div class="panel">
				<h3>AI automation</h3>
				<p class="prose">
					Placeholder copy for automating reimbursement flows, operational review, and internal
					tools with careful reliability boundaries.
				</p>
			</div>
			<div class="panel">
				<h3>Document intelligence</h3>
				<p class="prose">
					Placeholder copy for extracting structure from large document sets using NLP, embeddings,
					scraping, and data pipelines.
				</p>
			</div>
			<div class="panel">
				<h3>Experimental tools</h3>
				<p class="prose">
					Placeholder copy for prototypes across prediction, robotics, computer vision, and AI-first
					interfaces.
				</p>
			</div>
		</div>
	</Section>

	<Section
		eyebrow="Selected work"
		title="Professional systems with practical AI at the center."
		description="A short preview of polished case studies for production-oriented automation and document intelligence work."
	>
		<div class="grid grid--two">
			{
				workProjects.map((project) => (
					<ProjectCard
						title={project.title}
						href={project.href}
						eyebrow={project.eyebrow}
						description={project.summary}
						tags={project.tags}
					/>
				))
			}
		</div>
		<div class="link-row">
			<a class="button" href="/work">See all selected work</a>
		</div>
	</Section>

	<Section
		eyebrow="Lab"
		title="Exploratory projects, prototypes, and technical notes."
		description="The lab is intentionally looser than selected work: a place for experiments, early ideas, and smaller technical artifacts."
	>
		<div class="grid grid--three">
			{
				labProjects.map((project) => (
					<ProjectCard
						title={project.title}
						href={project.href}
						eyebrow={project.eyebrow}
						description={project.summary}
						tags={project.tags}
					/>
				))
			}
		</div>
		<div class="link-row">
			<a class="button" href="/lab">Open the lab</a>
		</div>
	</Section>

	<Section
		id="contact"
		eyebrow="Contact"
		title="Open to thoughtful software and AI systems conversations."
		description="Placeholder contact links for professional inquiries, collaboration, and project context."
		compact
	>
		<ul class="contact-list" aria-label="Contact links">
			<li><a href="mailto:bruno.farfan.miquel@uc.cl">Email</a></li>
			<li><a href="https://github.com/BrunoFarfan">GitHub</a></li>
			<li><a href="https://www.linkedin.com/in/bruno-farfan-miquel">LinkedIn</a></li>
		</ul>
	</Section>
</Layout>
