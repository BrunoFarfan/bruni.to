---
import PageHeader from '../components/PageHeader.astro';
import Section from '../components/Section.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="About me"
	description="Background and contact links for Bruno Farfan Miquel, a software and AI-oriented developer."
>
	<PageHeader
		eyebrow="About me"
		title="A software engineer focused on practical AI systems."
		description="Background and contact details for a portfolio centered on automation, document intelligence, software systems, and technical experiments."
	/>

	<Section title="Background" compact>
		<div class="prose">
			<p>
				Bruno Farfan Miquel is a software and AI-oriented developer based in Santiago, Chile. This
				portfolio scaffold is designed to grow into a focused record of professional systems,
				experiments, and technical notes.
			</p>
			<p>
				The background direction is informed by work in reimbursement automation, document
				intelligence, NLP pipelines, scraping, internal tools, AI teaching, and computer vision
				prototypes.
			</p>
		</div>
	</Section>

	<Section title="Contact" compact>
		<div class="contact-layout">
			<p class="contact-note">
				Based in Santiago, Chile. Best fit for conversations around AI automation, document-heavy
				software, internal tools, and experimental AI interfaces.
			</p>
			<ul class="contact-list" aria-label="Profile links">
				<li>
					<a href="mailto:bruno.farfan.miquel@uc.cl">
						<span>Email</span>
						<strong>bruno.farfan.miquel@uc.cl</strong>
					</a>
				</li>
				<li>
					<a href="https://github.com/BrunoFarfan">
						<span>GitHub</span>
						<strong>github.com/BrunoFarfan</strong>
					</a>
				</li>
				<li>
					<a href="https://www.linkedin.com/in/bruno-farfan-miquel">
						<span>LinkedIn</span>
						<strong>linkedin.com/in/bruno-farfan-miquel</strong>
					</a>
				</li>
				<li>
					<div class="contact-list__item">
						<span>Location</span>
						<strong>Santiago, Chile</strong>
					</div>
				</li>
			</ul>
		</div>
	</Section>
</Layout>
