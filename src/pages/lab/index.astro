---
import PageHeader from '../../components/PageHeader.astro';
import ScrollShowcase from '../../components/ScrollShowcase';
import Layout from '../../layouts/Layout.astro';
import { labProjects } from '../../data/projects';
---

<Layout
	title="Lab"
	description="Experimental projects and notes across AI tooling, prediction, robotics, and software systems."
>
	<PageHeader
		eyebrow="Lab"
		title="Experiments, prototypes, and technical notes."
		description="A lighter section for projects that are exploratory, unfinished, or useful as technical sketches."
	/>

	<ScrollShowcase client:load items={labProjects} />
</Layout>
