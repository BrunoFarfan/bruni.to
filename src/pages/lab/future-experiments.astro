---
import PageHeader from '../../components/PageHeader.astro';
import Section from '../../components/Section.astro';
import Layout from '../../layouts/Layout.astro';
import { labProjects } from '../../data/projects';

const project = labProjects[2];
---

<Layout
	title={project.title}
	description="A placeholder lab page for future AI tooling experiments, prototypes, and technical notes."
>
	<PageHeader
		eyebrow="Lab notes"
		title={project.title}
		description="A placeholder space for future AI tooling notes, small prototypes, and unfinished technical explorations."
	/>

	<Section compact>
		<div class="detail-layout">
			<article class="prose">
				<h2>Notes</h2>
				<p>
					This page is intentionally open-ended. It can become a lightweight index for short notes,
					experiment logs, sketches, and small tools that do not belong in selected work yet.
				</p>
				<p>
					Good future entries might cover evaluation harnesses, agent workflow prototypes, document
					parsing experiments, personal automation, or small interfaces for working with model outputs.
				</p>
			</article>

			<aside class="panel detail-aside" aria-label="Project facts">
				<dl class="fact-list">
					<div>
						<dt>Status</dt>
						<dd>{project.status}</dd>
					</div>
					<div>
						<dt>Focus</dt>
						<dd>{project.focus}</dd>
					</div>
					<div>
						<dt>Topics</dt>
						<dd>{project.tags.join(', ')}</dd>
					</div>
				</dl>
			</aside>
		</div>
	</Section>
</Layout>
