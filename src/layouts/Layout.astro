---
import Footer from "../components/Footer.astro";
import ParticleThemeToggle from "../components/ParticleThemeToggle";
import "../styles/global.css";

interface Props {
    title: string;
    description: string;
    canonicalPath?: string;
}

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;
const pageTitle = title;
const siteUrl = Astro.site ?? new URL("https://www.bruni.to");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const ogImageUrl = new URL("/og-image.png", siteUrl).toString();
const facebookAppId = import.meta.env.PUBLIC_FACEBOOK_APP_ID;
const personJsonLd = {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Bruno Farfán Miquel",
    url: "https://www.bruni.to/",
    jobTitle: "Software Engineer",
    sameAs: [
        "https://github.com/BrunoFarfan",
        "https://www.linkedin.com/in/bruno-farfan-miquel",
    ],
};
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/png" href="/favicon.png?v=2" />
        <link rel="shortcut icon" href="/favicon.ico?v=2" sizes="32x32" />
        <link rel="apple-touch-icon" href="/favicon.png?v=2" />
        <meta name="generator" content={Astro.generator} />
        <title>{pageTitle}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalUrl} />
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:image" content={ogImageUrl} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        {
            facebookAppId && (
                <meta property="fb:app_id" content={facebookAppId} />
            )
        }
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={pageTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageUrl} />
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify(personJsonLd)}
        />
        <script is:inline>
            try {
                const storedTheme = localStorage.getItem("theme");
                const prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                document.documentElement.dataset.theme =
                    storedTheme || (prefersDark ? "dark" : "light");
            } catch {
                document.documentElement.dataset.theme = "light";
            }
        </script>
    </head>
    <body>
        <a class="skip-link" href="#main">Skip to content</a>
        <ParticleThemeToggle client:load />
        <div class="site-shell">
            <main id="main" class="site-main">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
